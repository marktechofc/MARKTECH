rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid);
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isAdmin());

      match /orders/{orderId} {
        allow read, create: if signedIn() && request.auth.uid == userId;
        allow update, delete: if signedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /admins/{adminId} {
      allow read, write: if signedIn() && request.auth.uid == adminId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
